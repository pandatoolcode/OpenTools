async function queryTokenInfo(address, cacheKey) {
    if (!tronWeb||!userAddress) { showStatus('⚠️ 请先连接钱包','warning'); return null; }
    address = norm(address);
    if (isTrx(address)) {
        const info = {address:'TRX',name:'TRON',symbol:'TRX',decimals:6,balance:0,balanceRaw:'0'};
        try { const s=await tronWeb.trx.getBalance(userAddress); info.balanceRaw=String(s); info.balance=parseFloat((s/1e6).toFixed(6)); } catch(e){}
        tokenCache[cacheKey]=info; return info;
    }
    if (!address||address.length!==34||!address.startsWith('T')) { showStatus('⚠️ 无效地址','warning'); return null; }
    try {
        showStatus('🔍 查询中...','info');
        const c = await tronWeb.contract(TRC20_ABI, address);
        const [nR,sR,dR,bR] = await Promise.allSettled([c.name().call(),c.symbol().call(),c.decimals().call(),c.balanceOf(userAddress).call()]);
        const info = {
            address,
            name:     nR.status==='fulfilled'?(nR.value||'Unknown'):'Unknown',
            symbol:   sR.status==='fulfilled'?(sR.value||'???'):'???',
            decimals: dR.status==='fulfilled'?(typeof dR.value==='number'?dR.value:parseInt(dR.value.toString(),10)):6,
            balance:0, balanceRaw:'0'
        };
        if (bR.status==='fulfilled') {
            const s=typeof bR.value==='object'?bR.value.toString():String(bR.value);
            info.balanceRaw=s; info.balance=parseFloat(formatUnits(BigInt(s),info.decimals,6));
        }
        tokenCache[cacheKey]=info;
        showStatus(`✅ ${info.symbol}，余额: ${info.balance}`,'success',3000);
        return info;
    } catch(e) { showStatus('❌ '+e.message,'error'); return null; }
}

