    document.getElementById('expectedA').textContent=formatUnits(expA,lpState.tokenAInfo.decimals,6)+' '+lpState.tokenAInfo.symbol;
    document.getElementById('expectedB').textContent=formatUnits(expB,lpState.tokenBInfo.decimals,6)+' '+lpState.tokenBInfo.symbol;
    document.getElementById('burnLP').textContent=formatUnits(burn,18,6)+' LP';
}

async function removeLiquidity(){
    if(!tronWeb||!userAddress){showStatus('❌ 请先连接钱包','error');return;}
    if(!lpState.pairAddress||lpState.lpBalanceRaw<=0n){showStatus('⚠️ 请先查询 LP','warning');return;}
    const pct=parseInt(document.getElementById('removeSlider').value);
    const burn=(lpState.lpBalanceRaw*BigInt(pct))/100n;
    if(burn<=0n){showStatus('⚠️ 数量为 0','warning');return;}
    const tiA=lpState.tokenAInfo, tiB=lpState.tokenBInfo;
    const rA=lpState.token0IsA?lpState.reserve0:lpState.reserve1;
    const rB=lpState.token0IsA?lpState.reserve1:lpState.reserve0;
    const expA=(burn*rA)/lpState.totalSupply, expB=(burn*rB)/lpState.totalSupply;
    const mnA=applySlip(expA,slippage), mnB=applySlip(expB,slippage);
    const btn=document.getElementById('removeLiquidityBtn');
    btn.disabled=true;
    try {
        showStatus('🔑 授权 LP...','info');
        await ensureLPApproval(lpState.pairAddress,CONFIG.V2_ROUTER,burn);
        showStatus('⏳ 移除流动性...','info');
        const router=await tronWeb.contract(V2_ROUTER_ABI,CONFIG.V2_ROUTER);
        const dl=Math.floor(Date.now()/1000)+1200;
        const aTrx=isTrx(tiA.address), bTrx=isTrx(tiB.address);
        let txid;
        if(!aTrx&&!bTrx){
            txid=await router.removeLiquidity(tiA.address,tiB.address,burn.toString(),mnA.toString(),mnB.toString(),userAddress,dl)
                .send({feeLimit:CONFIG.FEE_LIMIT});
        } else {
            const ti=aTrx?tiB:tiA, tMn=aTrx?mnB:mnA, trxMn=aTrx?mnA:mnB;
            txid=await router.removeLiquidityETH(ti.address,burn.toString(),tMn.toString(),trxMn.toString(),userAddress,dl)
                .send({feeLimit:CONFIG.FEE_LIMIT});
        }
        if(txid){
            showStatus(`✅ 移除成功！<a href="${CONFIG.EXPLORER}/#/transaction/${txid}" target="_blank" style="color:var(--success)">查看</a>`,'success',15000);
            addTx('Remove Liquidity',`${pct}% ${tiA.symbol}/${tiB.symbol}`,'V2',txid);
            await sleep(2000); queryLPBalance();
        }
    } catch(e){
        console.error('removeLiquidity:',e);
        let msg=e.message||'未知错误';
        if(msg.includes('REVERT')) msg='交易被拒绝，尝试增大滑点';
        showStatus('❌ '+msg,'error');
    } finally{btn.disabled=false;}
}

/* ================================================================
   Transaction receipt checker
   ================================================================ */
async function checkTxResult(txid, retries, intervalMs){
    retries=retries||8; intervalMs=intervalMs||2500;
    for(var i=0;i<retries;i++){
        try{
            var info=await tronWeb.trx.getTransaction(txid);
            if(info&&info.ret&&info.ret[0]){
                var code=info.ret[0].contractRet;
                if(code==='SUCCESS') return true;
                if(code) return false;
            }
        } catch(e){console.warn('receipt check:',e.message);}
        await sleep(intervalMs);
    }
    return null;
}

