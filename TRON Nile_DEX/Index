            showStatus('⚠️ 此池中无流动性','warning');
            document.getElementById('removeLiquidityForm').style.display='none';
        } else {
            showStatus(`✅ LP 余额: ${lpState.lpBalance}`,'success',4000);
            document.getElementById('removeLiquidityForm').style.display='block';
            updateRemovePreview();
        }
    } catch(e){
        console.error('queryLP:',e);
        showStatus('❌ '+e.message,'error');
    } finally{btn.disabled=false;}
}

