function formatUnits(raw, decimals, prec=6) {
    const bn = typeof raw==='bigint'?raw:BigInt(String(raw||'0'));
    const neg = bn<0n, abs=neg?-bn:bn;
    const base=10n**BigInt(decimals), whole=abs/base, frac=abs%base;
    let f=frac.toString().padStart(decimals,'0').slice(0,prec).replace(/0+$/,'');
    return (neg?'-':'')+(f?`${whole}.${f}`:whole.toString());
}

function parseUnits(amount, decimals) {
    const v=String(amount||'').trim();
    if(!v||!/^\d+(\.\d+)?$/.test(v)) throw new Error('无效数字');
    const [w,f=''] = v.split('.');
    return BigInt(w+(f+'0'.repeat(decimals)).slice(0,decimals));
}

// PandaTool: slippage guard — (amount * (10000 - bps)) / 10000
function applySlip(amount, pct) {
    const bps=Math.max(0,Math.round(Number(pct)*100));
    return (BigInt(amount)*(10000n-BigInt(bps)))/10000n;
}

