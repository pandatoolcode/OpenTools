   ================================================================ */
let quoteValid=false;
async function updateQuote() {
    if (!tronWeb || !userAddress) return;

    const amt = document.getElementById('fromAmount').value;
    const fi = tokenCache['fromToken'];
    const ti = tokenCache['toToken'];

    const clear = () => {
        document.getElementById('toAmount').value = '';
        document.getElementById('rate').textContent = '-';
        document.getElementById('minReceived').textContent = '-';
        document.getElementById('priceImpact').textContent = '-';
        document.getElementById('swapBtn').disabled = true;
        quoteValid = false;
    };

    if (!amt || parseFloat(amt) <= 0 || !fi || !ti) {
        clear();
        return;
    }

    try {
        const wtrx = await getWtrx();
        const amtIn = parseUnits(amt, fi.decimals);

        // Use hex addresses for path to avoid TronWeb base58→hex encoding issues with address[]
        const fromBase58 = isTrx(fi.address) ? wtrx : fi.address;
        const toBase58   = isTrx(ti.address) ? wtrx : ti.address;
        const fromHex = tronWeb.address.toHex(fromBase58);
        const toHex   = tronWeb.address.toHex(toBase58);

        let outRaw = 0n;

        // Step 1: Try getAmountsOut with hex path
        try {
            const router = await tronWeb.contract(V2_ROUTER_ABI, CONFIG.V2_ROUTER);
            const r = await router.getAmountsOut(amtIn.toString(), [fromHex, toHex]).call();
            if (r && r.length >= 2) {
                const last = r[r.length - 1];
                const val = typeof last === 'object' && last._hex ? BigInt(last._hex) : BigInt(last.toString());
                if (val > 0n) outRaw = val;
            }
        } catch (e) {
            console.warn('getAmountsOut (hex):', e.message);
        }

        // Step 2: Fallback – query reserves directly from pair contract
        if (outRaw <= 0n) {
            try {
                const factory = await tronWeb.contract(V2_FACTORY_ABI, CONFIG.V2_FACTORY);
                const pairAddr = String(await factory.getPair(fromHex, toHex).call());
                if (!zeroPairAddress(pairAddr)) {
                    const pair = await tronWeb.contract(V2_PAIR_ABI, pairAddr);
                    const [resR, tok0R] = await Promise.all([
                        pair.getReserves().call(),
                        pair.token0().call()
                    ]);
                    const r0 = BigInt(resR._reserve0.toString());
                    const r1 = BigInt(resR._reserve1.toString());
                    if (r0 > 0n && r1 > 0n) {
                        const tok0Hex = String(tok0R).toLowerCase();
                        const isFrom0 = tok0Hex === fromHex.toLowerCase();
                        const resIn  = isFrom0 ? r0 : r1;
                        const resOut = isFrom0 ? r1 : r0;
                        // Uniswap V2 formula: amountOut = (amtIn * 997 * resOut) / (resIn * 1000 + amtIn * 997)
                        const amtInWithFee = amtIn * 997n;
                        outRaw = (amtInWithFee * resOut) / (resIn * 1000n + amtInWithFee);
                    }
                }
            } catch (e2) {
                console.warn('reserve fallback:', e2.message);
            }
        }

        if (outRaw <= 0n) {
            clear();
            document.getElementById('priceImpact').textContent = '无流动性';
            document.getElementById('rate').textContent = fi.symbol + '/' + ti.symbol + ' 无流动性池';
            showStatus('⚠️ ' + fi.symbol + '/' + ti.symbol + ' 交易对无流动性，无法兑换', 'warning', 8000);
            return;
        }

        const dispOut = formatUnits(outRaw, ti.decimals, 6);
        document.getElementById('toAmount').value = dispOut;

        const inN = parseFloat(amt);
        const outN = parseFloat(dispOut);
        document.getElementById('rate').textContent = inN > 0 ? ('1 ' + fi.symbol + ' ≈ ' + (outN / inN).toFixed(6) + ' ' + ti.symbol) : '-';

        const minRaw = applySlip(outRaw, slippage);
        document.getElementById('minReceived').textContent = formatUnits(minRaw, ti.decimals, 6) + ' ' + ti.symbol;
        document.getElementById('priceImpact').textContent = '< 1%';

        quoteValid = true;
        document.getElementById('swapBtn').disabled = false;
    } catch (e) {
        console.error('updateQuote:', e);
        clear();
    }
}

