// PandaTool: transaction record helper
function addTx(type, details, ver, txid, status){
    status=status||'success';
    var list=document.getElementById('transactionList');
    if(list.querySelector('[data-empty]')) list.innerHTML='';
    var icons={success:'✅ 成功',fail:'❌ 失败(Revert)',pending:'⏳ 待确认'};
    var colors={success:'var(--success)',fail:'var(--error)',pending:'var(--accent)'};
    var icon=icons[status]||icons.success, color=colors[status]||colors.success;
    var d=document.createElement('div');
    d.className='info-box'; d.style.marginBottom='10px';
    d.innerHTML='<div class="info-row"><span class="info-label">📝 '+type+' ('+ver+')</span><span class="info-value" style="color:'+color+'">'+icon+'</span></div>'
        +'<div class="info-row"><span class="info-label" style="font-size:10px">'+details+'</span><span class="info-value" style="font-size:10px">'+new Date().toLocaleTimeString()+'</span></div>'
        +'<div class="info-row"><span class="info-label" style="font-size:10px">TxID:</span><a href="'+CONFIG.EXPLORER+'/#/transaction/'+txid+'" target="_blank" style="font-size:9px;color:var(--secondary);word-break:break-all">'+txid.slice(0,24)+'...</a></div>';
    list.insertBefore(d,list.firstChild);
    while(list.children.length>5) list.removeChild(list.lastChild);
}

/* ================================================================
   Status
   ================================================================ */
let stTimer=null;
function showStatus(msg, type='info', dur=5000){
    const el=document.getElementById('statusMessage');
    el.className='status-message status-'+type;
    el.innerHTML=type==='info'?`<span class="spinner"></span>${msg}`:msg;
    if(stTimer) clearTimeout(stTimer);
    if(type!=='info'&&dur>0) stTimer=setTimeout(()=>{el.innerHTML='';el.className='';},dur);
}

/* ================================================================
   Event listeners
   ================================================================ */
function setup(){
    document.getElementById('connectWallet').addEventListener('click',connectWallet);

    // Tab switch
    document.querySelectorAll('.tab[data-tab]').forEach(t=>t.addEventListener('click',()=>{
        document.querySelectorAll('.tab[data-tab]').forEach(x=>x.classList.remove('active'));
        t.classList.add('active');
        const n=t.dataset.tab;
        document.getElementById('swapPanel').style.display           =n==='swap'           ?'block':'none';
        document.getElementById('addLiquidityPanel').style.display   =n==='addLiquidity'   ?'block':'none';
        document.getElementById('removeLiquidityPanel').style.display=n==='removeLiquidity'?'block':'none';
        if(n==='addLiquidity'&&tokenCache['liquidityTokenA']&&tokenCache['liquidityTokenB']){
            fetchPoolState();
        }
    }));

    // V2 only

    // Slippage
    document.querySelectorAll('.slippage-btn').forEach(b=>b.addEventListener('click',()=>{
        document.querySelectorAll('.slippage-btn').forEach(x=>x.classList.remove('active'));
        b.classList.add('active'); slippage=parseFloat(b.dataset.slippage);
        document.getElementById('customSlippage').value='';
        updateQuote(); updateRemovePreview();
    }));
    document.getElementById('customSlippage').addEventListener('input',function(){
        const v=parseFloat(this.value);
        if(v>0&&v<=50){
            slippage=v;
            document.querySelectorAll('.slippage-btn').forEach(x=>x.classList.remove('active'));
            updateQuote(); updateRemovePreview();
        }
    });

    // Direction swap
    document.getElementById('swapTokens').addEventListener('click',()=>{
        const fa=document.getElementById('fromTokenAddress').value;
        const ta=document.getElementById('toTokenAddress').value;
        document.getElementById('fromTokenAddress').value=ta;
        document.getElementById('toTokenAddress').value=fa;
        const tmp=tokenCache['fromToken'];
        tokenCache['fromToken']=tokenCache['toToken'];
        tokenCache['toToken']=tmp;
        if(tokenCache['fromToken']) updateTokenDisplay('from',tokenCache['fromToken']);
        if(tokenCache['toToken'])   updateTokenDisplay('to',tokenCache['toToken']);
        updateQuote();
    });

    // MAX
    document.getElementById('maxBtn').addEventListener('click',()=>{
        const info=tokenCache['fromToken'];
        if(info&&info.balance>0){
            let max=info.balance;
            if(isTrx(info.address)) max=Math.max(0,max-10);
            document.getElementById('fromAmount').value=max;
            updateQuote();
        }
    });

    // Query buttons
    document.getElementById('queryFromBtn').addEventListener('click',queryFromToken);
    document.getElementById('queryToBtn').addEventListener('click',queryToToken);
    document.getElementById('queryTokenABtn').addEventListener('click',queryLiquidityTokenA);
    document.getElementById('queryTokenBBtn').addEventListener('click',queryLiquidityTokenB);
    document.getElementById('queryLPBtn').addEventListener('click',queryLPBalance);

    // Actions
    document.getElementById('swapBtn').addEventListener('click',executeSwap);
    document.getElementById('addLiquidityBtn').addEventListener('click',addLiquidity);
    document.getElementById('removeLiquidityBtn').addEventListener('click',removeLiquidity);

    // Inputs
    const debounce=(fn,ms)=>{let t;return(...a)=>{clearTimeout(t);t=setTimeout(()=>fn(...a),ms);};};
    document.getElementById('fromAmount').addEventListener('input',debounce(updateQuote,600));
    document.getElementById('tokenAAmount').addEventListener('input', debounce(function(){ addLiqPool._lastEdited='A'; updateLiquidityPreview(); },400));
    document.getElementById('tokenBAmount').addEventListener('input', debounce(function(){ addLiqPool._lastEdited='B'; updateLiquidityPreview(); },400));
    document.getElementById('removeSlider').addEventListener('input',updateRemovePreview);
}

/* ================================================================
   Init
   ================================================================ */
// PandaTool DEX — entry point (pandatool.org)
async function init(){
    setup();
    if(window.tronLink&&window.tronLink.ready){
        tronWeb=window.tronLink.tronWeb||window.tronWeb;
        if(tronWeb&&tronWeb.defaultAddress&&tronWeb.defaultAddress.base58){
            userAddress=tronWeb.defaultAddress.base58;
            const btn=document.getElementById('connectWallet');
            btn.textContent='🟢 '+userAddress.slice(0,6)+'...'+userAddress.slice(-4);
            btn.style.background='linear-gradient(135deg,#00ff88,#00cc66)';
            showStatus('✅ 已自动连接','success',3000);
            setTimeout(()=>{queryFromToken();queryToToken();},800);
        }
    } else if(!window.tronLink){
        showStatus('⚠️ 请安装 TronLink 钱包扩展','warning',10000);
    }
}

window.addEventListener('load',init);
