async function executeSwap() {
    if(!tronWeb||!userAddress){showStatus('❌ 请先连接鑰包','error');return;}
    const fi=tokenCache['fromToken'], ti=tokenCache['toToken'];
    const amt=document.getElementById('fromAmount').value;
    if(!fi||!ti){showStatus('⚠️ 请先查询两个代币信息','warning');return;}
    if(!quoteValid){showStatus('⚠️ 当前交易对无流动性，无法兑换','warning');return;}
    if(fi.address===ti.address){showStatus('⚠️ 请选择不同的代币','warning');return;}
    if(!amt||parseFloat(amt)<=0){showStatus('⚠️ 请输入兑换数量','warning');return;}
    let amtIn;
    try{amtIn=parseUnits(amt,fi.decimals);}catch(e){showStatus('⚠️ 数量格式错误','warning');return;}
    const balRaw=BigInt(fi.balanceRaw||'0');
    if(amtIn>balRaw){showStatus('⚠️ 余额不足 (需 '+amt+' '+fi.symbol+'，有 '+fi.balance+')','error');return;}
    const btn=document.getElementById('swapBtn');
    btn.disabled=true;
    try {
        showStatus('⏳ 准备交易...','info');
        const deadline=Math.floor(Date.now()/1000)+1200;
        const dispOut=document.getElementById('toAmount').value||'0';
        const outRaw=parseUnits(dispOut||'0',ti.decimals);
        const outMin=applySlip(outRaw,slippage);
        const txid=await execV2(fi,ti,amtIn,outMin,deadline);
        if(txid){
            showStatus('⏳ 交易已提交，等待链上确认...','info');
            const receipt=await checkTxResult(txid);
            if(receipt===true){
                showStatus('✅ 兑换成功！ <a href="'+CONFIG.EXPLORER+'/#/transaction/'+txid+'" target="_blank" style="color:var(--success)">查看交易</a>','success',15000);
                addTx('Swap',amt+' '+fi.symbol+' → '+dispOut+' '+ti.symbol,'V2',txid,'success');
                queryFromToken(); queryToToken();
            } else if(receipt===false){
                showStatus('❌ 链上执行失败(Revert)！尝试加大滑点或检查流动性。 <a href="'+CONFIG.EXPLORER+'/#/transaction/'+txid+'" target="_blank" style="color:var(--error)">查看详情</a>','error',20000);
                addTx('Swap',amt+' '+fi.symbol+' → '+dispOut+' '+ti.symbol,'V2',txid,'fail');
            } else {
                showStatus('⚠️ 交易已提交，状态待确认。 <a href="'+CONFIG.EXPLORER+'/#/transaction/'+txid+'" target="_blank" style="color:var(--accent)">查看交易</a>','warning',15000);
                addTx('Swap',amt+' '+fi.symbol+' → '+dispOut+' '+ti.symbol,'V2',txid,'pending');
            }
        } else showStatus('❌ 交易失败，未获得哈希','error');
    } catch(e) {
        console.error('swap error:',e);
        let msg=e.message||'未知错误';
        if(msg.includes('REVERT')||msg.includes('revert')) msg='交易被拒绝：可能滑点过小或流动性不足，建议将滑点调至 1%-3%';
        else if(msg.includes('bandwidth')) msg='带宽不足，请质押 TRX 或保证足够 TRX 支付手续费';
        showStatus('❌ '+msg,'error');
    } finally {btn.disabled=false;}
}

async function execV2(fi, ti, amtIn, outMin, deadline) {
    const router=await tronWeb.contract(V2_ROUTER_ABI,CONFIG.V2_ROUTER);
    const wtrx=await getWtrx();
    const fTrx=isTrx(fi.address), tTrx=isTrx(ti.address);
    // PandaTool fix: use hex addresses for path[] — avoids TronWeb address[] encoding issues on Nile
    const wtrxHex = tronWeb.address.toHex(wtrx);
    const fromHex = fTrx ? wtrxHex : tronWeb.address.toHex(fi.address);
    const toHex   = tTrx ? wtrxHex : tronWeb.address.toHex(ti.address);
    if(fTrx){
        return await router.swapExactETHForTokens(outMin.toString(),[fromHex,toHex],userAddress,deadline)
            .send({callValue:amtIn.toString(),feeLimit:CONFIG.FEE_LIMIT});
    }
    if(tTrx){
        await ensureApproval(fi.address,CONFIG.V2_ROUTER,amtIn,fi.symbol);
        return await router.swapExactTokensForETH(amtIn.toString(),outMin.toString(),[fromHex,toHex],userAddress,deadline)
            .send({feeLimit:CONFIG.FEE_LIMIT});
    }
    await ensureApproval(fi.address,CONFIG.V2_ROUTER,amtIn,fi.symbol);
    return await router.swapExactTokensForTokens(amtIn.toString(),outMin.toString(),[fromHex,toHex],userAddress,deadline)
        .send({feeLimit:CONFIG.FEE_LIMIT});
}

