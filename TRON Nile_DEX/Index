// Pool state for add-liquidity panel
const addLiqPool = {
    exists: false,
    pairAddress: null,
    reserve0: 0n,
    reserve1: 0n,
    token0IsA: true,
    totalSupply: 0n,
    lastEdited: 'A',
    loading: false
};

function zeroPairAddress(addr) {
    const v = String(addr || '').trim();
    return !v || v === '0x0000000000000000000000000000000000000000' || v === '410000000000000000000000000000000000000000' || v === 'T9yD14Nj9j7xAB4dbGeiX9h8unkKHxuWwb';
}

function currentPoolRates() {
    const ta = tokenCache['liquidityTokenA'];
    const tb = tokenCache['liquidityTokenB'];
    if (!ta || !tb || !addLiqPool.exists || addLiqPool.reserve0 <= 0n || addLiqPool.reserve1 <= 0n) return null;

    const rA = addLiqPool.token0IsA ? addLiqPool.reserve0 : addLiqPool.reserve1;
    const rB = addLiqPool.token0IsA ? addLiqPool.reserve1 : addLiqPool.reserve0;
    const amountAFloat = Number(formatUnits(rA, ta.decimals, 12));
    const amountBFloat = Number(formatUnits(rB, tb.decimals, 12));
    if (!isFinite(amountAFloat) || !isFinite(amountBFloat) || amountAFloat <= 0) return null;

    return {
        reserveA: rA,
        reserveB: rB,
        reserveAFloat: amountAFloat,
        reserveBFloat: amountBFloat,
        ratioBPerA: amountBFloat / amountAFloat,
        ratioAPerB: amountAFloat / amountBFloat
    };
}

async function fetchPoolState() {
    const ta = tokenCache['liquidityTokenA'];
    const tb = tokenCache['liquidityTokenB'];
    if (!ta || !tb || !tronWeb || !userAddress) return;

    const poolStatusEl = document.getElementById('poolStatus');
    const poolRatioEl = document.getElementById('poolRatio');
    const poolShareEl = document.getElementById('poolShare');

    try {
        addLiqPool.loading = true;
        const wtrx = await getWtrx();
        const addrA = isTrx(ta.address) ? wtrx : ta.address;
        const addrB = isTrx(tb.address) ? wtrx : tb.address;

        const factory = await tronWeb.contract(V2_FACTORY_ABI, CONFIG.V2_FACTORY);
        const pairAddr = String(await factory.getPair(addrA, addrB).call());

        if (zeroPairAddress(pairAddr)) {
            addLiqPool.exists = false;
            addLiqPool.pairAddress = null;
            addLiqPool.reserve0 = 0n;
            addLiqPool.reserve1 = 0n;
            addLiqPool.token0IsA = true;
            addLiqPool.totalSupply = 0n;

            poolStatusEl.textContent = '新池子（首次创建）';
            poolStatusEl.style.color = 'var(--accent)';
            poolRatioEl.textContent = '首次创建时由你设定初始价格';
            poolShareEl.textContent = '100%';
            updateLiquidityPreview();
            return;
        }

        const pair = await tronWeb.contract(V2_PAIR_ABI, pairAddr);
        const [resR, tok0R, supR] = await Promise.all([
            pair.getReserves().call(),
            pair.token0().call(),
            pair.totalSupply().call()
        ]);

        const r0 = BigInt(resR._reserve0.toString());
        const r1 = BigInt(resR._reserve1.toString());
        const totalSupply = BigInt(supR.toString());

        // token0 compare must use hex-normalized address
        const hexA = tronWeb.address.toHex(addrA).toLowerCase();
        const tok0 = String(tok0R).toLowerCase();
        const token0IsA = tok0 === hexA;

        addLiqPool.exists = true;
        addLiqPool.pairAddress = pairAddr;
        addLiqPool.reserve0 = r0;
        addLiqPool.reserve1 = r1;
        addLiqPool.token0IsA = token0IsA;
        addLiqPool.totalSupply = totalSupply;

        const rA = token0IsA ? r0 : r1;
        const rB = token0IsA ? r1 : r0;

        const ratio = rA > 0n
            ? (Number(formatUnits(rB, tb.decimals, 12)) / Number(formatUnits(rA, ta.decimals, 12))).toFixed(6)
            : '-';

        poolStatusEl.textContent = '池子已存在';
        poolStatusEl.style.color = 'var(--success)';
        poolRatioEl.textContent = '1 ' + ta.symbol + ' = ' + ratio + ' ' + tb.symbol;
        updateLiquidityPreview();
    } catch (e) {
        console.warn('fetchPoolState:', e.message);
        addLiqPool.exists = false;
        addLiqPool.pairAddress = null;
        addLiqPool.reserve0 = 0n;
        addLiqPool.reserve1 = 0n;
        addLiqPool.token0IsA = true;
        addLiqPool.totalSupply = 0n;

        const poolStatusEl = document.getElementById('poolStatus');
        const poolRatioEl = document.getElementById('poolRatio');
        const poolShareEl = document.getElementById('poolShare');

        poolStatusEl.textContent = '查询失败';
        poolStatusEl.style.color = 'var(--error)';
        poolRatioEl.textContent = '-';
        poolShareEl.textContent = '-';
    } finally {
        addLiqPool.loading = false;
    }
}

function updateLiquidityPreview() {
    const ta = tokenCache['liquidityTokenA'];
    const tb = tokenCache['liquidityTokenB'];
    if (!ta || !tb) return;

    const aEl = document.getElementById('tokenAAmount');
    const bEl = document.getElementById('tokenBAmount');
    const poolStatusEl = document.getElementById('poolStatus');
    const poolRatioEl = document.getElementById('poolRatio');
    const poolShareEl = document.getElementById('poolShare');

    let aa = parseFloat(aEl.value || '0');
    let ab = parseFloat(bEl.value || '0');

    if (addLiqPool.exists) {
        const rates = currentPoolRates();
        if (!rates) {
            poolStatusEl.textContent = '池子已存在';
            poolRatioEl.textContent = '-';
            poolShareEl.textContent = '-';
            return;
        }

        if (addLiqPool.lastEdited === 'A' && aa > 0) {
            ab = aa * rates.ratioBPerA;
            bEl.value = ab.toFixed(6);
        } else if (addLiqPool.lastEdited === 'B' && ab > 0) {
            aa = ab * rates.ratioAPerB;
            aEl.value = aa.toFixed(6);
        } else if (aa > 0 && !ab) {
            ab = aa * rates.ratioBPerA;
            bEl.value = ab.toFixed(6);
        } else if (ab > 0 && !aa) {
            aa = ab * rates.ratioAPerB;
            aEl.value = aa.toFixed(6);
        }

        if (aa > 0 && ab > 0 && addLiqPool.totalSupply > 0n) {
            const rA = rates.reserveA;
            const rB = rates.reserveB;
            const dA = parseUnits(String(aa), ta.decimals);
            const dB = parseUnits(String(ab), tb.decimals);

            const liqByA = (dA * addLiqPool.totalSupply) / rA;
            const liqByB = (dB * addLiqPool.totalSupply) / rB;
            const minted = liqByA < liqByB ? liqByA : liqByB;

            const sharePct = Number(minted) > 0
                ? (Number(minted) / Number(addLiqPool.totalSupply + minted)) * 100
                : 0;

            poolShareEl.textContent = sharePct.toFixed(2) + '%';
        } else {
            poolShareEl.textContent = '-';
        }

        poolStatusEl.textContent = '池子已存在';
        poolStatusEl.style.color = 'var(--success)';
        poolRatioEl.textContent = '1 ' + ta.symbol + ' = ' + rates.ratioBPerA.toFixed(6) + ' ' + tb.symbol + '（自动按比例补齐）';
        return;
    }

    // New pool: user defines the initial price.
    if (aa > 0 && ab > 0) {
        poolStatusEl.textContent = '新池子（首次创建）';
        poolStatusEl.style.color = 'var(--accent)';
        poolRatioEl.textContent = '1 ' + ta.symbol + ' = ' + (ab / aa).toFixed(6) + ' ' + tb.symbol + '（初始价格）';
        poolShareEl.textContent = '100%';
    } else {
        poolStatusEl.textContent = '新池子（首次创建）';
        poolStatusEl.style.color = 'var(--accent)';
        poolRatioEl.textContent = '请输入 A / B 数量以设定初始价格';
        poolShareEl.textContent = '100%';
    }
}

async function addLiquidity() {
    if (!tronWeb || !userAddress) {
        showStatus('❌ 请先连接钱包', 'error');
        return;
    }

    const ta = tokenCache['liquidityTokenA'];
    const tb = tokenCache['liquidityTokenB'];
    const aRaw = document.getElementById('tokenAAmount').value;
    const bRaw = document.getElementById('tokenBAmount').value;

    if (!ta || !tb) {
        showStatus('⚠️ 请先查询两个代币', 'warning');
        return;
    }
    if (ta.address === tb.address) {
        showStatus('⚠️ 两个代币不能相同', 'warning');
        return;
    }

    const aNum = parseFloat(aRaw);
    const bNum = parseFloat(bRaw);
    if (!aRaw || !bRaw || !isFinite(aNum) || !isFinite(bNum) || aNum <= 0 || bNum <= 0) {
        showStatus('⚠️ 请输入有效数量', 'warning');
        return;
    }

    const btn = document.getElementById('addLiquidityBtn');
    btn.disabled = true;

    try {
        const router = await tronWeb.contract(V2_ROUTER_ABI, CONFIG.V2_ROUTER);
        const deadline = Math.floor(Date.now() / 1000) + 1200;

        let amountADesired = parseUnits(aRaw, ta.decimals);
        let amountBDesired = parseUnits(bRaw, tb.decimals);

        // Existing pool: recompute counterpart from current on-chain reserve ratio.
        if (addLiqPool.exists) {
            const rates = currentPoolRates();
            if (!rates) throw new Error('池子状态异常，无法读取储备');

            if (addLiqPool.lastEdited === 'A') {
                amountBDesired = (amountADesired * rates.reserveB) / rates.reserveA;
                document.getElementById('tokenBAmount').value = formatUnits(amountBDesired, tb.decimals, 6);
            } else if (addLiqPool.lastEdited === 'B') {
                amountADesired = (amountBDesired * rates.reserveA) / rates.reserveB;
                document.getElementById('tokenAAmount').value = formatUnits(amountADesired, ta.decimals, 6);
            } else {
                amountBDesired = (amountADesired * rates.reserveB) / rates.reserveA;
                document.getElementById('tokenBAmount').value = formatUnits(amountBDesired, tb.decimals, 6);
            }
        }

        const amountAMin = applySlip(amountADesired, slippage);
        const amountBMin = applySlip(amountBDesired, slippage);

        const aTrx = isTrx(ta.address);
        const bTrx = isTrx(tb.address);

        if (aTrx && bTrx) throw new Error('TRX 不能和 TRX 配对');

        let txid;
        if (!aTrx && !bTrx) {
            await ensureApproval(ta.address, CONFIG.V2_ROUTER, amountADesired, ta.symbol);
            await ensureApproval(tb.address, CONFIG.V2_ROUTER, amountBDesired, tb.symbol);

            txid = await router.addLiquidity(
                ta.address,
                tb.address,
                amountADesired.toString(),
                amountBDesired.toString(),
                amountAMin.toString(),
                amountBMin.toString(),
                userAddress,
                deadline
            ).send({ feeLimit: CONFIG.FEE_LIMIT });
        } else {
            const tokenAddr = aTrx ? tb.address : ta.address;
            const tokenDesired = aTrx ? amountBDesired : amountADesired;
            const tokenMin = aTrx ? amountBMin : amountAMin;
            const trxDesired = aTrx ? amountADesired : amountBDesired;
            const trxMin = aTrx ? amountAMin : amountBMin;

            await ensureApproval(tokenAddr, CONFIG.V2_ROUTER, tokenDesired, aTrx ? tb.symbol : ta.symbol);

            txid = await router.addLiquidityETH(
                tokenAddr,
                tokenDesired.toString(),
                tokenMin.toString(),
                trxMin.toString(),
                userAddress,
                deadline
            ).send({ callValue: trxDesired.toString(), feeLimit: CONFIG.FEE_LIMIT });
        }

        if (txid) {
            showStatus('⏳ 交易已提交，等待确认...', 'info');
            const receipt = await checkTxResult(txid);
            const shownA = formatUnits(amountADesired, ta.decimals, 6);
            const shownB = formatUnits(amountBDesired, tb.decimals, 6);

            if (receipt === true) {
                showStatus('✅ 流动性添加成功！ <a href="' + CONFIG.EXPLORER + '/#/transaction/' + txid + '" target="_blank" style="color:var(--success)">查看交易</a>', 'success', 15000);
                addTx('Add Liquidity', shownA + ' ' + ta.symbol + ' + ' + shownB + ' ' + tb.symbol, 'V2', txid, 'success');
                await sleep(1500);
                await fetchPoolState();
                queryLiquidityTokenA();
                queryLiquidityTokenB();
            } else if (receipt === false) {
                showStatus('❌ 流动性添加失败(Revert)。 <a href="' + CONFIG.EXPLORER + '/#/transaction/' + txid + '" target="_blank" style="color:var(--error)">查看详情</a>', 'error', 20000);
                addTx('Add Liquidity', shownA + ' ' + ta.symbol + ' + ' + shownB + ' ' + tb.symbol, 'V2', txid, 'fail');
            } else {
                showStatus('⚠️ 交易已提交，状态待确认。 <a href="' + CONFIG.EXPLORER + '/#/transaction/' + txid + '" target="_blank" style="color:var(--accent)">查看交易</a>', 'warning', 15000);
                addTx('Add Liquidity', shownA + ' ' + ta.symbol + ' + ' + shownB + ' ' + tb.symbol, 'V2', txid, 'pending');
            }
        }
    } catch (e) {
        console.error('addLiquidity:', e);
        showStatus('❌ ' + (e.message || '未知错误'), 'error');
    } finally {
        btn.disabled = false;
    }
}

